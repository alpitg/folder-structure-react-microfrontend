{
  "version": "1.0",
  "name": "Micro Meal Planner",
  "description": "A microservice for managing meal-planner data",
  "author": "Meal Planner Team",
  "logo": "/static/media/img/logo.png",
  "api": {
    "baseUrl": "http://localhost:8000",
    "frontendBaseUrl": "",
    "apiVersion": "v1",
    "mealPlanner": {
      "mealRequest": "/api/meal-planner/meal-request",
      "availableIngredients": "/api/meal-planner/available-ingredients",
      "weeklyPlan": "/api/meal-planner/weekly-plans"
    },
    "administration": {
      "organizationUnits": {
        "list": "/api/organization-units",
        "detail": "/api/organization-units/{id}",
        "add": "/api/organization-units",
        "update": "/api/organization-units/{id}",
        "delete": "/api/organization-units/{id}",
        "roles": {
          "list": "/api/organization-units/{id}/roles/search",
          "add": "/api/organization-units/roles/add",
          "remove": "/api/organization-units/roles/remove"
        }
      },
      "roles": {
        "list": "/api/roles/search",
        "detail": "/api/roles/{id}",
        "add": "/api/roles",
        "update": "/api/roles/{id}",
        "delete": "/api/roles/{id}",
        "permissions": "/api/roles-permissions"
      },
      "users": {
        "login": "/api/auth/login",
        "refreshToken": "/api/auth/refresh",
        "appInit": "/api/auth/users/me/app-init",
        "forgotPassword": "/api/auth/forgot-password",
        "resetPassword": "/api/auth/reset-password",
        "updatePassword": "/api/auth/users/{id}/change-password",
        "getCurrentUserProfile": "/api/auth/users/{id}/current-user-profile",
        "updateCurrentUserProfile": "/api/auth/users/{id}/current-user-profile",
        "list": "/api/users/search",
        "detail": "/api/users/{id}",
        "add": "/api/users/create",
        "update": "/api/users/{id}",
        "delete": "/api/users/{id}",
        "getUserForEdit": "/api/users/get-user-for-edit?id={id}",
        "permissions": "/api/users/permissions"
      }
    },
    "profile": {
      "mealPlanner": "/api/profile/frame-types"
    },
    "master": {
      "frameTypes": "/api/master/frame-types",
      "glassTypes": "/api/master/glass-types",
      "miscCharges": "/api/master/misc-charges"
    },
    "order": {
      "list": "/api/orders/search",
      "listGet": "/api/orders",
      "detail": "/api/orders/{orderId}",
      "placeOrder": "/api/orders/place-order",
      "update": "/api/orders/{orderId}"
    },
    "catalog": {
      "product": {
        "list": "/api/products/search",
        "detail": "/api/products/{id}",
        "add": "/api/products",
        "update": "/api/products/{id}"
      },
      "category": {
        "list": "/api/products/category/search",
        "detail": "/api/products/category/{id}",
        "add": "/api/products/category",
        "update": "/api/products/category/{id}"
      }
    },
    "customer": {
      "list": "/api/customer/search",
      "detail": "/api/customer/{id}",
      "add": "/api/customer",
      "update": "/api/customer/{id}",
      "delete": "/api/customer/delete"
    }
  }
}
